{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://pozputxlgfbqywlvxfot.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "zango-mcp",
      "version": "0.1.0",
      "title": "ZANGO"
    },
    "tools": [
      {
        "name": "search_products",
        "title": "Search products",
        "description": "Search active ZANGO product listings by keyword. Returns up to 20 products with name, price (NGN), category, seller store name and slug, and city.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200,
              "description": "Keyword to match against product name and description."
            },
            "city": {
              "description": "Optional city name filter, e.g. 'Kano'.",
              "type": "string",
              "maxLength": 80
            },
            "limit": {
              "default": 10,
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_my_bookmarks",
        "title": "List my bookmarks",
        "description": "List products the signed-in user has bookmarked on ZANGO.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_my_seller_profile",
        "title": "Get my seller profile",
        "description": "Return the signed-in user's ZANGO seller profile if they have one: business name, category, city, verification and onboarding status, and public store slug.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_my_products",
        "title": "List my products",
        "description": "List products owned by the signed-in ZANGO seller (any status). Empty for buyers or sellers with no listings.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
